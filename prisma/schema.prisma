generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime   @default(now())
  accounts      Account[]
  favorites     Favorite[]
  builds        Build[]
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  heroId    Int
  heroName  String
  heroHead  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, heroId])
}

model Build {
  id        String   @id @default(cuid())
  userId    String
  heroId    Int
  heroName  String
  heroHead  String
  item1     String   @default("")
  item2     String   @default("")
  item3     String   @default("")
  item4     String   @default("")
  item5     String   @default("")
  item6     String   @default("")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}
